---
import type { Artwork } from '../types/artwork';

interface Props {
  artworks: Artwork[];
  title?: string;
  showFilters?: boolean;
  description?: string;
}

const { artworks, title = 'Selected Works', showFilters = true, description } = Astro.props;
const categories = Array.from(new Set(artworks.flatMap((artwork) => artwork.categories))).sort();
const layoutPattern = ['art-card art-card--feature', 'art-card', 'art-card art-card--tall', 'art-card art-card--wide', 'art-card', 'art-card art-card--tall'];
---

<section class="gallery-shell" data-gallery-root>
  <p class="section-label">Gallery</p>
  <h2>{title}</h2>
  {description ? <p>{description}</p> : null}

  {
    showFilters && categories.length > 0 ? (
      <div class="gallery-toolbar">
        <div class="category-filter" role="toolbar" aria-label="Filter artworks by category">
          <button type="button" data-filter="all" aria-pressed="true">All</button>
          {categories.map((category) => (
            <button type="button" data-filter={category} aria-pressed="false">
              {category}
            </button>
          ))}
        </div>
      </div>
    ) : null
  }

  <div class="gallery-grid" data-gallery-grid>
    {
      artworks.length === 0 ? (
        <div class="empty-state">No artwork has been published yet.</div>
      ) : (
        artworks.map((artwork, index) => (
          <article
            class={layoutPattern[index % layoutPattern.length]}
            data-card
            data-categories={artwork.categories.join(',')}
            style={`--stagger:${(index % 10) * 65}ms`}
          >
            <button
              type="button"
              data-lightbox-open
              data-title={artwork.title}
              data-meta={`${artwork.medium} / ${artwork.year}`}
              data-alt={artwork.alt}
              data-webp={artwork.images.full.webp}
              data-jpg={artwork.images.full.jpg}
            >
              <picture>
                <source srcset={artwork.images.medium.webp} type="image/webp" />
                <img
                  src={artwork.images.medium.jpg}
                  alt={artwork.alt}
                  loading="lazy"
                  decoding="async"
                  width="1200"
                  height="900"
                />
              </picture>
              <div class="art-meta">
                <h3>{artwork.title}</h3>
                <p>{artwork.medium} / {artwork.year}</p>
              </div>
            </button>
          </article>
        ))
      )
    }
  </div>
</section>

<dialog class="lightbox" data-lightbox>
  <button type="button" class="lightbox__close" data-lightbox-close aria-label="Close">&#x2715;</button>
  <button type="button" class="lightbox__nav lightbox__nav--prev" data-lightbox-prev aria-label="Previous artwork">&#x2039;</button>
  <button type="button" class="lightbox__nav lightbox__nav--next" data-lightbox-next aria-label="Next artwork">&#x203A;</button>
  <figure class="lightbox__figure">
    <picture>
      <source data-lightbox-source type="image/webp" />
      <img data-lightbox-image alt="" width="2000" height="1300" />
    </picture>
    <figcaption class="lightbox__caption">
      <strong data-lightbox-title></strong>
      <p data-lightbox-meta></p>
      <p class="lightbox__counter" data-lightbox-counter></p>
    </figcaption>
  </figure>
</dialog>

<script>
  const galleryRoot = document.querySelector('[data-gallery-root]');

  if (galleryRoot instanceof HTMLElement) {
    const filterButtons = Array.from(galleryRoot.querySelectorAll('[data-filter]'));
    const cards = Array.from(galleryRoot.querySelectorAll('[data-card]'));
    const openers = Array.from(galleryRoot.querySelectorAll('[data-lightbox-open]'));

    const lightboxDialog = document.querySelector('[data-lightbox]');
    if (!(lightboxDialog instanceof HTMLDialogElement)) throw new Error('missing lightbox');

    const lightboxTitle = lightboxDialog.querySelector('[data-lightbox-title]') as HTMLElement;
    const lightboxMeta = lightboxDialog.querySelector('[data-lightbox-meta]') as HTMLElement;
    const lightboxSource = lightboxDialog.querySelector('[data-lightbox-source]') as HTMLSourceElement;
    const lightboxImage = lightboxDialog.querySelector('[data-lightbox-image]') as HTMLImageElement;
    const lightboxCounter = lightboxDialog.querySelector('[data-lightbox-counter]') as HTMLElement;
    const prevBtn = lightboxDialog.querySelector('[data-lightbox-prev]') as HTMLButtonElement;
    const nextBtn = lightboxDialog.querySelector('[data-lightbox-next]') as HTMLButtonElement;

    // Build ordered list of visible artwork data
    let items: { title: string; meta: string; webp: string; jpg: string; alt: string }[] = [];
    let currentIndex = 0;

    function buildItems() {
      items = openers
        .filter((btn) => {
          const card = btn.closest('[data-card]');
          return card && !card.hasAttribute('hidden');
        })
        .map((btn) => ({
          title: btn.getAttribute('data-title') ?? '',
          meta: btn.getAttribute('data-meta') ?? '',
          webp: btn.getAttribute('data-webp') ?? '',
          jpg: btn.getAttribute('data-jpg') ?? '',
          alt: btn.getAttribute('data-alt') ?? '',
        }));
    }

    function showItem(index: number) {
      const item = items[index];
      if (!item) return;
      currentIndex = index;

      lightboxTitle.textContent = item.title;
      lightboxMeta.textContent = item.meta;
      lightboxSource.setAttribute('srcset', item.webp);
      lightboxImage.setAttribute('src', item.jpg);
      lightboxImage.setAttribute('alt', item.alt);
      lightboxCounter.textContent = `${index + 1} / ${items.length}`;

      prevBtn.style.display = items.length > 1 ? '' : 'none';
      nextBtn.style.display = items.length > 1 ? '' : 'none';
    }

    function navigate(delta: number) {
      if (items.length <= 1) return;
      const next = ((currentIndex + delta) % items.length + items.length) % items.length;
      showItem(next);
    }

    // Category filtering
    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.getAttribute('data-filter') ?? 'all';
        filterButtons.forEach((c) => c.setAttribute('aria-pressed', String(c === button)));
        cards.forEach((card) => {
          const cats = (card.getAttribute('data-categories') ?? '').split(',').filter(Boolean);
          card.toggleAttribute('hidden', target !== 'all' && !cats.includes(target));
        });
      });
    });

    // Open lightbox
    openers.forEach((button) => {
      button.addEventListener('click', () => {
        buildItems();
        const card = button.closest('[data-card]');
        const visibleOpeners = openers.filter((btn) => {
          const c = btn.closest('[data-card]');
          return c && !c.hasAttribute('hidden');
        });
        const idx = visibleOpeners.indexOf(button);
        showItem(idx >= 0 ? idx : 0);
        lightboxDialog.showModal();
      });
    });

    // Navigation buttons
    prevBtn.addEventListener('click', (e) => { e.stopPropagation(); navigate(-1); });
    nextBtn.addEventListener('click', (e) => { e.stopPropagation(); navigate(1); });

    // Keyboard navigation
    lightboxDialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); navigate(1); }
    });

    // Close
    lightboxDialog.querySelector('[data-lightbox-close]')?.addEventListener('click', () => {
      lightboxDialog.close();
    });

    lightboxDialog.addEventListener('click', (event) => {
      if (event.target === lightboxDialog) lightboxDialog.close();
    });
  }
</script>
