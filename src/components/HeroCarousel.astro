---
import type { Artwork } from '../types/artwork';

interface Props {
  artworks: Artwork[];
}

const { artworks } = Astro.props;

const slides = artworks.map((artwork, i) => ({
  id: artwork.id,
  title: artwork.title,
  subtitle: `${artwork.medium}, ${artwork.year}`,
  alt: artwork.alt,
  webp: artwork.images.hero.webp,
  jpg: artwork.images.hero.jpg,
  kb: (i % 5) + 1,
}));

const fallbackSlides = [
  { id: 'tex-1', title: 'Studio Texture I', subtitle: '', alt: 'Canvas texture in cyan and charcoal tones', webp: '', jpg: '/textures/texture-1.svg', kb: 1 },
  { id: 'tex-2', title: 'Studio Texture II', subtitle: '', alt: 'Abstract brush texture in cyan and orange', webp: '', jpg: '/textures/texture-2.svg', kb: 2 },
  { id: 'tex-3', title: 'Studio Texture III', subtitle: '', alt: 'Layered paper texture in warm contrast tones', webp: '', jpg: '/textures/texture-3.svg', kb: 3 },
];

const finalSlides = slides.length > 0 ? slides : fallbackSlides;
---

<div class="hero-cinematic" data-hero-cinematic>
  <div class="hero-cinematic__stage">
    {finalSlides.map((slide, i) => (
      <div
        class:list={['hero-cinematic__slide', i === 0 && 'is-active']}
        data-slide-index={i}
        data-kb={slide.kb}
      >
        <picture>
          {slide.webp ? <source srcset={slide.webp} type="image/webp" /> : null}
          <img
            src={slide.jpg}
            alt={slide.alt}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : undefined}
            draggable="false"
          />
        </picture>
      </div>
    ))}

    <div class="hero-cinematic__vignette"></div>

    <div class="hero-cinematic__overlay">
      <div class="hero-cinematic__meta" data-hero-meta>
        <p class="hero-cinematic__title" data-hero-title>{finalSlides[0]?.title ?? ''}</p>
        <p class="hero-cinematic__subtitle" data-hero-subtitle>{finalSlides[0]?.subtitle ?? ''}</p>
      </div>

      {finalSlides.length > 1 && (
        <div class="hero-cinematic__dots" role="tablist" aria-label="Artwork slides">
          {finalSlides.map((slide, i) => (
            <button
              type="button"
              role="tab"
              class:list={['hero-cinematic__dot', i === 0 && 'is-active']}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`View ${slide.title}`}
              data-dot-index={i}
            >
              <span class="hero-cinematic__dot-fill"></span>
            </button>
          ))}
        </div>
      )}
    </div>
  </div>
</div>

<script is:inline>
(() => {
  const root = document.querySelector('[data-hero-cinematic]');
  if (!(root instanceof HTMLElement)) return;

  const slides = Array.from(root.querySelectorAll('[data-slide-index]'));
  const dots = Array.from(root.querySelectorAll('[data-dot-index]'));
  const titleEl = root.querySelector('[data-hero-title]');
  const subtitleEl = root.querySelector('[data-hero-subtitle]');
  const metaEl = root.querySelector('[data-hero-meta]');

  if (slides.length <= 1) return;

  const titles = slides.map(s => s.getAttribute('data-title') || '');
  const subtitles = slides.map(s => s.getAttribute('data-subtitle') || '');

  let active = 0;
  let paused = false;
  const INTERVAL = 6500;
  const FADE = 1400;

  // Store metadata from the Astro-rendered data attributes
  const slideMeta = [];
  const metaOverlay = root.querySelector('.hero-cinematic__overlay');

  // Read initial titles from the rendered slide elements - we'll pull from dots' aria-labels
  dots.forEach((dot, i) => {
    const label = dot.getAttribute('aria-label') || '';
    const title = label.replace('View ', '');
    slideMeta.push({ title });
  });

  function goTo(index) {
    if (index === active) return;
    const prev = active;
    active = index;

    slides.forEach((slide, i) => {
      slide.classList.toggle('is-active', i === active);
      slide.classList.toggle('is-leaving', i === prev);
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle('is-active', i === active);
      dot.setAttribute('aria-selected', String(i === active));
    });

    // Fade meta text
    if (metaEl instanceof HTMLElement) {
      metaEl.classList.add('is-transitioning');
      setTimeout(() => {
        if (titleEl) titleEl.textContent = slideMeta[active]?.title || '';
        // Rebuild subtitle from slide data
        metaEl.classList.remove('is-transitioning');
      }, 400);
    }

    // Clean up leaving class after fade
    setTimeout(() => {
      slides[prev]?.classList.remove('is-leaving');
    }, FADE + 100);
  }

  function advance() {
    if (paused) return;
    goTo((active + 1) % slides.length);
  }

  let timer = setInterval(advance, INTERVAL);

  // Pause on hover (desktop)
  root.addEventListener('mouseenter', () => { paused = true; });
  root.addEventListener('mouseleave', () => { paused = false; });

  // Dot clicks
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(advance, INTERVAL);
    });
  });

  // Respect reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    clearInterval(timer);
  }
})();
</script>
