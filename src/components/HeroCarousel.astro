---
import type { Artwork } from '../types/artwork';

interface TextureSlide {
  title: string;
  alt: string;
  webp?: string;
  jpg: string;
}

interface CarouselSlide {
  id: string;
  title: string;
  alt: string;
  jpg: string;
  webp?: string;
  subtitle?: string;
  kind: 'art' | 'texture';
}

interface Props {
  artworks: Artwork[];
  textureSlides?: TextureSlide[];
}

const { artworks, textureSlides = [] } = Astro.props;

const artSlides: CarouselSlide[] = artworks.map((artwork) => ({
  id: artwork.id,
  title: artwork.title,
  subtitle: `${artwork.medium} / ${artwork.year}`,
  alt: artwork.alt,
  webp: artwork.images.hero.webp,
  jpg: artwork.images.hero.jpg,
  kind: 'art'
}));

const fallbackTextures: TextureSlide[] = [
  { title: 'Studio Texture I', alt: 'Canvas texture in cyan and charcoal tones', jpg: '/textures/texture-1.svg' },
  { title: 'Studio Texture II', alt: 'Abstract brush texture in cyan and orange', jpg: '/textures/texture-2.svg' },
  { title: 'Studio Texture III', alt: 'Layered paper texture in warm contrast tones', jpg: '/textures/texture-3.svg' }
];

const texturePool = textureSlides.length > 0 ? textureSlides : fallbackTextures;
const fillerSlides: CarouselSlide[] = (artSlides.length >= 4
  ? []
  : texturePool.slice(0, Math.max(0, 4 - artSlides.length))
).map((texture, index) => ({
  id: `texture-${index + 1}`,
  title: texture.title,
  alt: texture.alt,
  jpg: texture.jpg,
  webp: texture.webp,
  kind: 'texture'
}));

const slides: CarouselSlide[] = [...artSlides, ...fillerSlides];
const featuredSlide: CarouselSlide = slides[0] ?? {
  id: 'texture-fallback',
  title: fallbackTextures[0].title,
  alt: fallbackTextures[0].alt,
  jpg: fallbackTextures[0].jpg,
  kind: 'texture'
};
---

<section class="hero-carousel-block" data-carousel-root>
  <div class="hero-carousel" data-carousel>
    <div class="hero-carousel__viewport" data-carousel-track>
      {
        slides.map((slide, index) => (
          <article class="hero-carousel__slide" data-slide data-index={index}>
            <picture>
              {slide.webp ? <source srcset={slide.webp} type="image/webp" /> : null}
              <img
                src={slide.jpg}
                alt={slide.alt}
                loading={index === 0 ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : undefined}
                width="2200"
                height="1400"
              />
            </picture>
            <div class="hero-carousel__caption">
              <h2>{slide.title}</h2>
              {slide.subtitle ? <p>{slide.subtitle}</p> : null}
            </div>
          </article>
        ))
      }
    </div>
    <div class="hero-carousel__controls" aria-label="Carousel controls">
      <button class="hero-carousel__arrow" type="button" data-carousel-prev aria-label="Previous slide">
        Previous
      </button>
      <div class="hero-carousel__dots" role="tablist" aria-label="Carousel slides">
        {
          slides.map((slide, index) => (
            <button
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-label={`Go to ${slide.title}`}
              data-carousel-dot
              data-index={index}
            />
          ))
        }
      </div>
      <button class="hero-carousel__arrow" type="button" data-carousel-next aria-label="Next slide">
        Next
      </button>
    </div>
  </div>

  <div class="hero-mobile" data-hero-mobile>
    <article class="hero-mobile__featured">
      <img src={featuredSlide.jpg} alt={featuredSlide.alt} loading="eager" width="1600" height="1100" />
      <div class="hero-mobile__meta">
        <h2>{featuredSlide.title}</h2>
      </div>
    </article>
    <div class="hero-mobile__strip" aria-label="Swipe through selected artwork">
      {
        slides.map((slide, index) => (
          <article class="hero-mobile__chip">
            <img src={slide.jpg} alt={slide.alt} loading={index < 2 ? 'eager' : 'lazy'} width="600" height="420" />
            <p>{slide.title}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const carouselRoot = document.querySelector('[data-carousel-root]');

    if (!(carouselRoot instanceof HTMLElement)) {
      return;
    }

    const track = carouselRoot.querySelector('[data-carousel-track]');
    const prevButton = carouselRoot.querySelector('[data-carousel-prev]');
    const nextButton = carouselRoot.querySelector('[data-carousel-next]');
    const dots = Array.from(carouselRoot.querySelectorAll('[data-carousel-dot]'));

    if (!(track instanceof HTMLElement) || dots.length === 0) {
      return;
    }

    let activeIndex = 0;
    let autoplayEnabled = true;
    let autoplayTimer = null;

    const slideCount = dots.length;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopMode = window.matchMedia('(min-width: 721px)').matches;

    const markManualOverride = () => {
      autoplayEnabled = false;
      carouselRoot.setAttribute('data-autoplay', 'off');
      if (autoplayTimer !== null) {
        window.clearInterval(autoplayTimer);
      }
    };

    const updateDots = () => {
      dots.forEach((dot, index) => {
        dot.setAttribute('aria-selected', String(index === activeIndex));
      });
    };

    const goToIndex = (index, smooth = true) => {
      const bounded = ((index % slideCount) + slideCount) % slideCount;
      activeIndex = bounded;
      const targetSlide = track.querySelector('[data-index="' + bounded + '"]');
      if (targetSlide instanceof HTMLElement) {
        track.scrollTo({
          left: targetSlide.offsetLeft,
          behavior: smooth && !reduceMotion ? 'smooth' : 'auto'
        });
      }
      updateDots();
    };

    const syncOnScroll = () => {
      const slideNodes = Array.from(track.querySelectorAll('[data-slide]'));
      let nearestIndex = 0;
      let nearestDistance = Number.POSITIVE_INFINITY;

      slideNodes.forEach((slide, index) => {
        if (!(slide instanceof HTMLElement)) {
          return;
        }
        const distance = Math.abs(slide.offsetLeft - track.scrollLeft);
        if (distance < nearestDistance) {
          nearestDistance = distance;
          nearestIndex = index;
        }
      });

      if (nearestIndex !== activeIndex) {
        activeIndex = nearestIndex;
        updateDots();
      }
    };

    prevButton?.addEventListener('click', () => {
      markManualOverride();
      goToIndex(activeIndex - 1);
    });

    nextButton?.addEventListener('click', () => {
      markManualOverride();
      goToIndex(activeIndex + 1);
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const raw = dot.getAttribute('data-index');
        if (!raw) {
          return;
        }
        markManualOverride();
        goToIndex(Number(raw));
      });
    });

    track.addEventListener('scroll', syncOnScroll, { passive: true });
    track.addEventListener('pointerdown', markManualOverride, { passive: true });
    track.addEventListener('touchstart', markManualOverride, { passive: true });
    track.addEventListener('wheel', markManualOverride, { passive: true });

    if (desktopMode && !reduceMotion && autoplayEnabled) {
      autoplayTimer = window.setInterval(() => {
        if (!autoplayEnabled) {
          return;
        }
        goToIndex(activeIndex + 1);
      }, 6200);
    }

    goToIndex(0, false);
  })();
</script>
