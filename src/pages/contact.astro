---
import Layout from '../layouts/Layout.astro';

const contactEmail = 'jeffconnersart@gmail.com';
---

<Layout title="Contact | Jeff Conners" description="Contact Jeff Conners for commissions and availability.">
  <section class="hero flow-section flow-section--first reveal">
    <p class="section-label">Contact</p>
    <h1>
      Let's talk about
      <span class="accent">your walls.</span>
    </h1>
    <p>Commissions, prints, or questions about existing work — reach out directly.</p>
  </section>

  <section class="panel flow-section reveal" aria-label="Contact options">
    <p class="section-label">Email</p>
    <div class="copy-row">
      <code id="contact-email">{contactEmail}</code>
      <button type="button" id="copy-email">Copy Email</button>
      <a class="cta" href={`mailto:${contactEmail}?subject=Artwork Inquiry`}>Open Mail</a>
    </div>
    <p id="copy-status" aria-live="polite" style="margin-top:0.9rem;color:var(--muted);"></p>
  </section>

  <section class="panel flow-section reveal" aria-label="Social">
    <p class="section-label">Social</p>
    <a class="cta" href="https://www.facebook.com/profile.php?id=61574884405561" target="_blank" rel="noopener">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align:middle;margin-right:0.5rem;"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>Follow on Facebook
    </a>
  </section>

  <script>
    const copyButton = document.querySelector('#copy-email');
    const emailEl = document.querySelector('#contact-email');
    const statusEl = document.querySelector('#copy-status');

    copyButton?.addEventListener('click', async () => {
      if (!(emailEl instanceof HTMLElement) || !(statusEl instanceof HTMLElement)) {
        return;
      }

      const email = emailEl.textContent ?? '';
      try {
        await navigator.clipboard.writeText(email);
        statusEl.textContent = 'Email copied.';
      } catch {
        statusEl.textContent = 'Clipboard access blocked. Copy manually from the email text.';
      }
    });
  </script>
</Layout>
