---
import GalleryGrid from '../components/GalleryGrid.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import Layout from '../layouts/Layout.astro';
import { getAllArtworks, getFeaturedArtworks } from '../lib/artworks';

const allArtworks = getAllArtworks();
const featured = getFeaturedArtworks(8);
const showcase = featured.length > 0 ? featured : allArtworks.slice(0, 8);
---

<Layout
  title="Jeff Conners | Contemporary Artwork"
  description="Original artwork by Jeff Conners — contrast, rhythm, and texture through a colorblind-informed lens."
  snap={true}
>
  <section class="hero-full snap-section">
    <HeroCarousel artworks={showcase} />
    <div class="hero-full__copy reveal">
      <h1>
        Shape before color.
        <span class="accent">Feeling before explanation.</span>
      </h1>
      <p>
        Jeff Conners paints through a colorblind lens — contrast, rhythm, and texture
        guide each composition where convention cannot.
      </p>
    </div>
  </section>

  <section class="two-col flow-section snap-section reveal" aria-label="Artist summary">
    <article class="panel">
      <p class="section-label">The Work</p>
      <p>
        Each painting starts as a shape study — tonal sketches that find their way into
        acrylic and mixed-media sessions. The finished pieces sit here without distraction.
      </p>
    </article>
    <a class="panel panel-link" href="/contact">
      <p class="section-label">Commissions</p>
      <p>
        Interested in a piece or a custom work? Reach out directly for availability, sizing, and pricing.
      </p>
      <span class="cta" style="display:inline-flex;margin-top:1rem;">Get In Touch</span>
    </a>
  </section>

  <section class="flow-section flow-section--gallery snap-section reveal" aria-label="Featured gallery">
    <GalleryGrid
      artworks={showcase}
      title="Selected Work"
      showFilters={false}
    />
  </section>
</Layout>
