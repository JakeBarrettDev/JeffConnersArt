---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  snap?: boolean;
}

const {
  title = 'Jeff Conners | Artwork',
  description = 'A minimalist, art-first portfolio featuring original work by Jeff Conners.',
  snap = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Outfit:wght@300;350;400;450;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={[snap && 'snap-enabled']}>
    <div class="page-shell">
      <header class="site-header" data-site-header>
        <a href="/" class="brand">Jeff Conners</a>
        <nav aria-label="Primary">
          <a href="/gallery">Gallery</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="https://www.facebook.com/profile.php?id=61574884405561" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <nav class="footer-nav" aria-label="Footer">
            <a href="/gallery">Gallery</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="https://www.facebook.com/profile.php?id=61574884405561" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </nav>
          <div class="footer-brand">
            <a href="https://MaroonRaccoon.dev" class="footer-logo" target="_blank" rel="noopener" aria-label="Maroon Raccoon LLC">
              <img src="/maroon-raccoon.svg" alt="Maroon Raccoon" width="28" height="28" />
            </a>
            <p>Maroon Raccoon LLC &times; Jeff Conners</p>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const header = document.querySelector('[data-site-header]');
      if (header instanceof HTMLElement) {
        const toggleScrolled = () => {
          header.classList.toggle('is-scrolled', window.scrollY > 24);
        };

        toggleScrolled();
        window.addEventListener('scroll', toggleScrolled, { passive: true });
      }
    </script>
  </body>
</html>
