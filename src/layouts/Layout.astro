---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  snap?: boolean;
}

const {
  title = 'Jeff Conners | Artwork',
  description = 'A minimalist, art-first portfolio featuring original work by Jeff Conners.',
  snap = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={[snap && 'snap-enabled']}>
    <div class="page-shell">
      <header class="site-header" data-site-header>
        <a href="/" class="brand">Jeff Conners</a>
        <nav aria-label="Primary">
          <a href="/gallery">Gallery</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Maroon Raccoon LLC x Jeff Conners</p>
      </footer>
    </div>

    <script>
      const header = document.querySelector('[data-site-header]');
      if (header instanceof HTMLElement) {
        const toggleScrolled = () => {
          header.classList.toggle('is-scrolled', window.scrollY > 24);
        };

        toggleScrolled();
        window.addEventListener('scroll', toggleScrolled, { passive: true });
      }
    </script>
  </body>
</html>
